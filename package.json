{
  "name": "modbusmate",
  "version": "0.1.0",
  "private": true,
  "description": "Modbus 设备调试器 — Modbus-TCP 调试工具",
  "author": "xmlju",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "MM_DEV=1 electron .",
    "test": "vitest run",
    "sim": "node test/simulator.js",
    "sim:bat": "node scripts/simulate-device.js 8502 battery",
    "sim:plc": "node scripts/simulate-device.js 8503 plc",
    "sim:temp": "node scripts/simulate-device.js 8504 temp",
    "sim:all": "node scripts/simulate-device.js 8502 battery & node scripts/simulate-device.js 8503 plc & node scripts/simulate-device.js 8504 temp",
    "dist": "electron-builder"
  },
  "dependencies": {
    "modbus-serial": "^8.0.17"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.yaominghua.modbusmate",
    "productName": "Modbus 设备调试器",
    "files": [
      "main/**",
      "renderer/**",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "legalTrademarks": "ModbusMate"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": false,
      "unicode": true,
      "artifactName": "${productName}-安装版-${version}-win64.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-便携版-${version}-win64.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    }
  }
}
